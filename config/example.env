# AWS middleware
APP_ENV=dev
LOG_LEVEL=info
INTERNAL_SHARED_SECRET=replace-for-pilot-only
REQUIRE_BEARER_TOKEN=false
# Comma-separated list of allowed CORS origins. Use * only for local/dev.
ALLOWED_ORIGINS=*
# Container HTTP port (used by the Docker/server.ts entrypoint).
PORT=8080

# Entra ID JWT validation (production auth). When both are set, the middleware
# verifies the bearer token signature, issuer, audience, and expiry.
ENTRA_TENANT_ID=
ENTRA_AUDIENCE=
# Optional issuer override; defaults to https://login.microsoftonline.com/<tenant>/v2.0
ENTRA_ISSUER=

# Ivanti tenant
IVANTI_BASE_URL=https://your-tenant.ivanticloud.com
IVANTI_ODATA_PATH=/api/odata/businessobject
IVANTI_TIMEOUT_MS=8000
# Local/pilot credential. In AWS, leave this empty and set IVANTI_SECRET_ARN so
# the value is read from Secrets Manager instead of the environment.
IVANTI_AUTH_HEADER_VALUE=Bearer replace-with-token-or-session-value
# IVANTI_SECRET_ARN=arn:aws:secretsmanager:us-east-1:000000000000:secret:ivanti-copilot/dev/ivanti-auth

# Ivanti business objects
IVANTI_KB_OBJECT=KnowledgeArticles
IVANTI_INCIDENT_OBJECT=Incidents

# Knowledge field mapping
IVANTI_FIELD_ID=RecId
IVANTI_FIELD_TITLE=Title
IVANTI_FIELD_SUMMARY=Summary
IVANTI_FIELD_BODY=Body
IVANTI_FIELD_STATUS=Status
IVANTI_FIELD_CATEGORY=Category
IVANTI_FIELD_UPDATED_AT=LastModDateTime
IVANTI_ARTICLE_URL_TEMPLATE=https://your-tenant.ivanticloud.com/knowledge/{id}

# Incident field mapping
IVANTI_INCIDENT_FIELD_ID=RecId
IVANTI_INCIDENT_FIELD_NUMBER=IncidentNumber
IVANTI_INCIDENT_FIELD_SUBJECT=Subject
IVANTI_INCIDENT_FIELD_DESCRIPTION=Symptom
IVANTI_INCIDENT_FIELD_RESOLUTION=Resolution
IVANTI_INCIDENT_FIELD_STATUS=Status
IVANTI_INCIDENT_FIELD_CATEGORY=Category
IVANTI_INCIDENT_FIELD_CLOSED_AT=ClosedDateTime

